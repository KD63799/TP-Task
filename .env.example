# ── Docker Registry ────────────────────────────────────────────────────────
# Votre nom d'utilisateur Docker Hub (hub.docker.com)
DOCKER_USER=your_dockerhub_username

# ── Serveur distant ─────────────────────────────────────────────────────────
# IP ou hostname du serveur cible
REMOTE_HOST=1.2.3.4

# Utilisateur SSH sur le serveur (ex: ubuntu, debian, root)
REMOTE_USER=ubuntu

# Répertoire de déploiement sur le serveur — doit exister avant le premier deploy
REMOTE_DIR=/opt/tp-task

# Port SSH (22 par défaut)
REMOTE_PORT=22
